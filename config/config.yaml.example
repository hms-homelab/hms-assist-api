homeassistant:
  url: http://192.168.2.7:8123
  token: YOUR_HA_LONG_LIVED_TOKEN

database:
  host: 192.168.2.15
  port: 5432
  name: hms_assist
  user: maestro
  password: YOUR_DB_PASSWORD
  # Direct connection to the HA recorder DB for fast entity ingestion
  ha_db_name: homeassistant

ollama:
  url: http://192.168.2.5:11434
  embed_model: nomic-embed-text
  fast_model: llama3.1:8b-instruct-q4_K_M
  smart_model: gpt-oss:120b-cloud
  # Confidence threshold below which 8b escalates to smart_model
  escalation_threshold: 0.7

wyoming:
  piper_host: 192.168.2.5
  piper_port: 10200
  whisper_host: 192.168.2.5
  whisper_port: 10300

service:
  port: 8894
  # Minimum cosine similarity for Tier 2 vector search match
  vector_similarity_threshold: 0.82
  # How many vector search results to consider
  vector_search_limit: 5
