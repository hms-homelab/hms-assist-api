homeassistant:
  url: http://192.168.2.7:8123          # Your HA instance URL
  token: YOUR_LONG_LIVED_TOKEN_HERE     # Settings → Long-lived access tokens

database:
  host: localhost
  port: 5432
  name: hms_assist
  user: maestro
  password: YOUR_DB_PASSWORD
  ha_db_name: homeassistant             # HA recorder DB (for fast entity sync)
                                        # Leave empty to use REST API instead

ollama:
  url: http://192.168.2.5:11434         # Ollama server URL
  embed_model: nomic-embed-text         # Embedding model (768-dim)
  fast_model: llama3.1:8b-instruct-q4_K_M   # Tier 3a: fast LLM
  smart_model: llama3.1:70b-instruct-q4_K_M # Tier 3b: fallback LLM
  escalation_threshold: 0.7             # Confidence below which tier3a escalates

wyoming:
  piper_host: 192.168.2.5              # Wyoming Piper TTS host
  piper_port: 10200
  whisper_host: 192.168.2.5           # Wyoming Whisper STT host
  whisper_port: 10300

service:
  port: 8894
  vector_similarity_threshold: 0.58   # Minimum cosine similarity for tier2 match
  vector_search_limit: 5              # Max candidates returned by pgvector
